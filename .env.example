# ============================================
# Luni Cloud — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# === Server ===
DOMAIN=luni.example.com
SECRET_KEY=change-this-to-a-random-64-char-string
LOG_LEVEL=info                          # debug | info | warning | error
ENVIRONMENT=production                  # development | production

# === Database (PostgreSQL) ===
# Avoid using $ in the password — Docker Compose interprets $x as a variable.
# If you must use $, escape it as $$ (e.g. pa$$word).
DB_PASSWORD=change-this-to-a-strong-password

# === Redis ===
# (internal Docker network, usually no change needed)
REDIS_URL=redis://redis:6379/0

# === Cloudflare ===/
CF_TUNNEL_TOKEN=your-tunnel-token-from-cloudflare-dashboard
CF_R2_ACCOUNT_ID=your-account-id
CF_R2_ACCESS_KEY=your-r2-access-key
CF_R2_SECRET_KEY=your-r2-secret-key
CF_R2_BUCKET=luni-firmware

# === AI Container (Phase 2) ===
AI_SERVICE_URL=http://ai:8081           # luni-ai container (internal Docker network)
STT_LANGUAGE=vi                         # Default STT language

# === External Data ===
OPENWEATHER_API_KEY=your-weather-api-key

# === UI Preview ===
UI_PREVIEW_PATH=D:/Luni_Robot/ui_design   # Path to ui_design folder on host

# === JWT ===
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
