# ============================================
# Luni AI Container — Environment Variables
# Copy this file to .env and fill in real keys (do NOT commit .env).
# ============================================

# --- Orchestration ---
# Comma-separated fallback order. Remove a name to disable that backend.
CHAT_BACKENDS=aimode,gemini,openai_compat
CHAT_FALLBACK_MESSAGE=Xin lỗi, hiện tại mình chưa kết nối được. Bạn thử lại sau một chút nhé!

# --- PRIMARY: Google AI Mode (Playwright headless Chromium) ---
AIMODE_ENABLED=true
AIMODE_URL_TEMPLATE=https://www.google.com/search?udm=50&hl=vi&gl=vn&q={query}
AIMODE_TIMEOUT_MS=8000
AIMODE_NAV_TIMEOUT_MS=6000
AIMODE_HEADLESS=true
AIMODE_LOCALE=vi-VN
# Optional: comma-separated CSS selectors for the AI answer container.
# Leave empty to use built-in defaults; tune against the live page if needed.
AIMODE_ANSWER_SELECTORS=

# --- BACKUP 1: Gemini (Google AI Studio REST) ---
GEMINI_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=12000
GEMINI_GROUNDING=false

# --- BACKUP 2: gemma-4 (OpenAI-compatible endpoint, from check_api.py) ---
OPENAI_COMPAT_ENABLED=true
OPENAI_COMPAT_BASE_URL=http://171.226.10.121:8000
OPENAI_COMPAT_PATH=/llm/v1/chat/completions
OPENAI_COMPAT_TOKEN=gemma4-openclaw-2026
OPENAI_COMPAT_MODEL=gemma-4
OPENAI_COMPAT_MAX_TOKENS=512
OPENAI_COMPAT_TEMPERATURE=0.5
OPENAI_COMPAT_TIMEOUT_MS=20000

# --- Emotion selection (LLM picks 1 of 45 robot emotion keys from the reply) ---
# auto = try gemma (openai_compat) first, then Gemini, then keyword heuristic.
EMOTION_PICKER=auto
EMOTION_TIMEOUT_MS=5000

# --- Persona / generation ---
LUNI_MAX_HISTORY=10
LOG_LEVEL=INFO

# ============================================
# Future STT/TTS work (still stubbed at 501) — left here for reference:
# --- faster-whisper (local STT) ---
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
# --- Piper TTS (local) ---
# PIPER_VOICE=vi_VN-vais1000-medium
