# ============================================
# Luni AI Container — Environment Variables
# Copy this file to .env and configure based on your AI implementation
# ============================================

# Uncomment and configure based on your chosen implementation:

# --- Gemini (free tier) ---
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.0-flash

# --- Ollama (local LLM) ---
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:7b

# --- faster-whisper (local STT) ---
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu

# --- Piper TTS (local) ---
# PIPER_VOICE=vi_VN-vais1000-medium
